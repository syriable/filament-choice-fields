{
    "name": "syriable/filament-choice-fields",
    "description": "This is my package filament-choice-fields",
    "keywords": [
        "syriable",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "filament-choice-fields"
    ],
    "homepage": "https://github.com/syriable/filament-choice-fields",
    "support": {
        "issues": "https://github.com/syriable/filament-choice-fields/issues",
        "source": "https://github.com/syriable/filament-choice-fields"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "syriable",
            "email": "info@syriable.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1|^8.2|^8.3|^8.4",
        "filament/forms": "^4.0|^5.0",
        "spatie/laravel-package-tools": "^1.15.0",
        "codewithdennis/filament-advanced-choice": "^2.1.1"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.7|^4.0",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0",
        "rector/rector": "^2.0",
        "spatie/laravel-ray": "^1.26"
    },
    "autoload": {
        "psr-4": {
            "Syriable\\Filament\\Plugins\\Translations\\ChoiceFields\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Syriable\\Filament\\Plugins\\Translations\\ChoiceFields\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "phpstan analyse --memory-limit=512M",
        "lint": "pint",
        "refactor": "rector",
        "test": "pest",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Syriable\\Filament\\Plugins\\Translations\\ChoiceFields\\ChoiceFieldsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}